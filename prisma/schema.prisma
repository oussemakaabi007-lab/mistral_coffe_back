generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Utilisateur {
  id             Int            @id @default(autoincrement())
  nomUtilisateur String         @unique
  motDePasse     String
  role           Role           @default(SERVEUR)
  actif          Boolean        @default(true)
  createdAt      DateTime       @default(now())
  logs           JournalLog[]
  sessions       SessionPoste[]
  ventes         Vente[]

  @@map("utilisateurs")
}

model Ingredient {
  id            Int                  @id @default(autoincrement())
  nom           String               @unique
  quantiteStock Float                @default(0)
  uniteMesure   String
  seuilAlerte   Float                @default(0)
  recettes      CompositionRecette[]

  @@map("ingredients")
}

model Categorie {
  id       Int       @id @default(autoincrement())
  nom      String    @unique
  actif    Boolean   @default(true)
  produits Produit[]

  @@map("categories")
}

model Produit {
  id          Int                  @id @default(autoincrement())
  nom         String               @unique
  prix        Decimal              @db.Decimal(10, 3)
  actif       Boolean              @default(true)
  imageUrl    String?
  remise      Decimal              @default(0.000) @db.Decimal(10, 3)
  categorieId Int
  recette     CompositionRecette[]
  lignesVente LigneVente[]
  categorie   Categorie            @relation(fields: [categorieId], references: [id])

  @@map("produits")
}

model CompositionRecette {
  id              Int        @id @default(autoincrement())
  produitId       Int
  ingredientId    Int
  quantiteRequise Float
  ingredient      Ingredient @relation(fields: [ingredientId], references: [id])
  produit         Produit    @relation(fields: [produitId], references: [id], onDelete: Cascade)

  @@unique([produitId, ingredientId])
  @@map("composition_recettes")
}

model SessionPoste {
  id            Int         @id @default(autoincrement())
  utilisateurId Int
  type          TypePoste
  dateOuverture DateTime    @default(now())
  dateFermeture DateTime?
  fondDeCaisse  Decimal     @db.Decimal(10, 3)
  caisseReelle  Decimal?    @db.Decimal(10, 3)
  statut        String      @default("OUVERT")
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id])
  ventes        Vente[]

  @@map("sessions_poste")
}

model Vente {
  id             Int          @id @default(autoincrement())
  dateVente      DateTime     @default(now())
  montantTotal   Decimal      @db.Decimal(10, 3)
  statut         String       @default("COMPLETED")
  sessionPosteId Int
  utilisateurId  Int
  lignes         LigneVente[]
  sessionPoste   SessionPoste @relation(fields: [sessionPosteId], references: [id])
  utilisateur    Utilisateur  @relation(fields: [utilisateurId], references: [id])

  @@map("ventes")
}

model LigneVente {
  id        Int     @id @default(autoincrement())
  venteId   Int
  produitId Int
  quantite  Int
  produit   Produit @relation(fields: [produitId], references: [id])
  vente     Vente   @relation(fields: [venteId], references: [id], onDelete: Cascade)

  @@map("lignes_vente")
}

model JournalLog {
  id            Int          @id @default(autoincrement())
  action        String
  description   String
  timestamp     DateTime     @default(now())
  utilisateurId Int?
  utilisateur   Utilisateur? @relation(fields: [utilisateurId], references: [id])

  @@map("journal_logs")
}

enum Role {
  ADMIN
  GERANT
  SERVEUR
}

enum TypePoste {
  AVANT_MIDI
  APRES_MIDI
}